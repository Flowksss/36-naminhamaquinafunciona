# Database — use Neon (neon.tech) free tier
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth — gere com: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# E-mail (recuperação de senha) — opcional em dev.
# Sem RESEND_API_KEY, o link de reset é apenas logado no console em dev.
# Para envio real, crie uma chave em https://resend.com e configure na Vercel.
RESEND_API_KEY=""
EMAIL_FROM="CCT SINCRO <onboarding@resend.dev>"

# Telemetria — CCT SimWorld (mundo de simulação que expõe APIs OEM).
# Default local: http://localhost:3100. Em produção, aponte para o host
# persistente do SimWorld (Render/Railway/VM — não Vercel serverless).
SIMWORLD_URL="http://localhost:3100"

# Segredo do job de Cron de telemetria (Vercel Cron envia no header).
CRON_SECRET=""
