generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Tenant raiz do SaaS. Uma organização (cliente) possui N fazendas/unidades
// e N usuários. TODO isolamento multiunidade parte daqui.
model Organizacao {
  id        String      @id @default(cuid())
  nome      String
  plano     PlanoTier   @default(START)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  usuarios  User[]
  fazendas  Fazenda[]
  ativos    Ativo[]
}

enum PlanoTier {
  START
  GROWTH
  ENTERPRISE
}

model User {
  id             String      @id @default(cuid())
  name           String
  email          String      @unique
  password       String
  role           Role        @default(OPERADOR)
  organizacaoId  String
  organizacao    Organizacao @relation(fields: [organizacaoId], references: [id])
  resetTokens    PasswordResetToken[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([organizacaoId])
}

// Token de recuperação de senha. Guardamos só o HASH (SHA-256) do token;
// o valor cru vive apenas no link enviado por e-mail. Expira e é de uso único.
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

enum Role {
  ADMIN
  GERENTE
  OPERADOR
}

model Fazenda {
  id             String      @id @default(cuid())
  nome           String
  area           Float
  localizacao    String
  tipoSolo       String?
  organizacaoId  String
  organizacao    Organizacao @relation(fields: [organizacaoId], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  safras         Safra[]
  ativos         Ativo[]

  @@index([organizacaoId])
}

model Safra {
  id                   String      @id @default(cuid())
  fazendaId            String
  fazenda              Fazenda     @relation(fields: [fazendaId], references: [id])
  cultura              String
  dataPlantio          DateTime
  dataColheitaPrevista DateTime
  dataColheitaReal     DateTime?
  areaPlantada         Float
  status               StatusSafra @default(PLANEJADA)
  quantidadePrevista   Float?
  quantidadeReal       Float?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  movimentos           MovimentoEstoque[]
  transacoes           Transacao[]
}

enum StatusSafra {
  PLANEJADA
  EM_ANDAMENTO
  COLHIDA
  CANCELADA
}

model Insumo {
  id                String     @id @default(cuid())
  nome              String
  tipo              TipoInsumo
  unidade           String
  quantidadeEstoque Float      @default(0)
  estoqueMinimo     Float      @default(0)
  precoUnitario     Float?
  fornecedorId      String?
  fornecedor        Fornecedor? @relation(fields: [fornecedorId], references: [id])
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  movimentos        MovimentoEstoque[]
}

enum TipoInsumo {
  SEMENTE
  FERTILIZANTE
  DEFENSIVO
  COMBUSTIVEL
  OUTRO
}

model MovimentoEstoque {
  id         String        @id @default(cuid())
  insumoId   String
  insumo     Insumo        @relation(fields: [insumoId], references: [id])
  safraId    String?
  safra      Safra?        @relation(fields: [safraId], references: [id])
  tipo       TipoMovimento
  quantidade Float
  data       DateTime      @default(now())
  observacao String?
  createdAt  DateTime      @default(now())
}

enum TipoMovimento {
  ENTRADA
  SAIDA
}

model Fornecedor {
  id         String      @id @default(cuid())
  nome       String
  cnpj       String?     @unique
  email      String?
  telefone   String?
  endereco   String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  insumos    Insumo[]
  transacoes Transacao[]
}

model Cliente {
  id         String      @id @default(cuid())
  nome       String
  cnpj       String?     @unique
  email      String?
  telefone   String?
  endereco   String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  transacoes Transacao[]
}

model Transacao {
  id           String        @id @default(cuid())
  tipo         TipoTransacao
  valor        Float
  descricao    String
  data         DateTime
  safraId      String?
  safra        Safra?        @relation(fields: [safraId], references: [id])
  fornecedorId String?
  fornecedor   Fornecedor?   @relation(fields: [fornecedorId], references: [id])
  clienteId    String?
  cliente      Cliente?      @relation(fields: [clienteId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

enum TipoTransacao {
  RECEITA
  DESPESA
}

// ============================================================
// FROTA / INTELIGÊNCIA OPERACIONAL (pivô)
// ============================================================

model Ativo {
  id             String       @id @default(cuid())
  identificador  String       @unique // placa ou código (ex: "CAM-32")
  tipo           TipoAtivo    @default(CAMINHAO)
  status         StatusAtivo  @default(OCIOSO)
  organizacaoId  String
  organizacao    Organizacao  @relation(fields: [organizacaoId], references: [id])
  fazendaId      String
  fazenda        Fazenda      @relation(fields: [fazendaId], references: [id])
  lat            Float?
  lng            Float?
  consumoMedio   Float        @default(0) // baseline L/h estimado
  consumoAtual   Float        @default(0) // L/h corrente (do feed simulado)
  capacidadeTanque Float?
  nivelCombustivel Float?      // % 0-100
  horasDesdeManutencao Float   @default(0) // horas de operação desde a última manutenção
  modelo         String?      // ex: "John Deere 8R"
  ano            Int?
  operador       String?      // motorista/operador responsável
  horimetroTotal Float        @default(0) // horas totais acumuladas
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  posicoes       PosicaoGPS[]

  @@index([organizacaoId])
  @@index([fazendaId])
}

// Trilha de posições GPS (histórico) — para mapa + rotas.
model PosicaoGPS {
  id        String   @id @default(cuid())
  ativoId   String
  ativo     Ativo    @relation(fields: [ativoId], references: [id], onDelete: Cascade)
  lat       Float
  lng       Float
  consumo   Float?   // L/h naquele ciclo (histórico por ativo)
  nivel     Float?   // % combustível naquele ciclo
  tick      Int      @default(0)
  createdAt DateTime @default(now())

  @@index([ativoId, tick])
}

enum TipoAtivo {
  CAMINHAO
  COLHEDORA
  TRATOR
  PULVERIZADOR
  OUTRO
}

enum StatusAtivo {
  EM_OPERACAO
  NA_FILA
  EM_TRANSITO
  OCIOSO
  MANUTENCAO
}

model Recomendacao {
  id              String              @id @default(cuid())
  organizacaoId   String
  tick            Int                 @default(0) // qual ciclo da simulação gerou
  tipo            TipoRecomendacao
  severidade      Severidade          @default(MEDIA)
  mensagem        String
  ativoId         String?
  fazendaOrigemId String?
  fazendaDestinoId String?
  status          StatusRecomendacao  @default(ATIVA)
  createdAt       DateTime            @default(now())

  @@index([organizacaoId, status])
}

enum TipoRecomendacao {
  REDESPACHO
  FILA_ALTA
  ALERTA_CONSUMO
  ABASTECIMENTO
  MANUTENCAO
}

enum Severidade {
  BAIXA
  MEDIA
  ALTA
}

enum StatusRecomendacao {
  ATIVA
  RESOLVIDA
}

// Estado da simulação por organização (1 linha por org). Controla o "tick".
model SimState {
  id            String   @id @default(cuid())
  organizacaoId String   @unique
  tick          Int      @default(0)
  updatedAt     DateTime @updatedAt
}

// Snapshot agregado por ciclo — para gráficos de tendência ao longo dos ticks.
model SnapshotOperacional {
  id            String   @id @default(cuid())
  organizacaoId String
  tick          Int
  criadoEm      DateTime @default(now())
  totalAtivos   Int      @default(0)
  emFila        Int      @default(0)
  emOperacao    Int      @default(0)
  alertas       Int      @default(0)
  manutencoes   Int      @default(0)
  consumoTotal  Float    @default(0)
  desperdicioDia Float   @default(0) // R$/dia de diesel desperdiçado (menor = melhor)

  @@index([organizacaoId, tick])
}
