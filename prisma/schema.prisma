generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(OPERADOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  GERENTE
  OPERADOR
}

model Fazenda {
  id          String   @id @default(cuid())
  nome        String
  area        Float
  localizacao String
  tipoSolo    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  safras      Safra[]
  ativos      Ativo[]
}

model Safra {
  id                   String      @id @default(cuid())
  fazendaId            String
  fazenda              Fazenda     @relation(fields: [fazendaId], references: [id])
  cultura              String
  dataPlantio          DateTime
  dataColheitaPrevista DateTime
  dataColheitaReal     DateTime?
  areaPlantada         Float
  status               StatusSafra @default(PLANEJADA)
  quantidadePrevista   Float?
  quantidadeReal       Float?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  movimentos           MovimentoEstoque[]
  transacoes           Transacao[]
}

enum StatusSafra {
  PLANEJADA
  EM_ANDAMENTO
  COLHIDA
  CANCELADA
}

model Insumo {
  id                String     @id @default(cuid())
  nome              String
  tipo              TipoInsumo
  unidade           String
  quantidadeEstoque Float      @default(0)
  estoqueMinimo     Float      @default(0)
  precoUnitario     Float?
  fornecedorId      String?
  fornecedor        Fornecedor? @relation(fields: [fornecedorId], references: [id])
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  movimentos        MovimentoEstoque[]
}

enum TipoInsumo {
  SEMENTE
  FERTILIZANTE
  DEFENSIVO
  COMBUSTIVEL
  OUTRO
}

model MovimentoEstoque {
  id         String        @id @default(cuid())
  insumoId   String
  insumo     Insumo        @relation(fields: [insumoId], references: [id])
  safraId    String?
  safra      Safra?        @relation(fields: [safraId], references: [id])
  tipo       TipoMovimento
  quantidade Float
  data       DateTime      @default(now())
  observacao String?
  createdAt  DateTime      @default(now())
}

enum TipoMovimento {
  ENTRADA
  SAIDA
}

model Fornecedor {
  id         String      @id @default(cuid())
  nome       String
  cnpj       String?     @unique
  email      String?
  telefone   String?
  endereco   String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  insumos    Insumo[]
  transacoes Transacao[]
}

model Cliente {
  id         String      @id @default(cuid())
  nome       String
  cnpj       String?     @unique
  email      String?
  telefone   String?
  endereco   String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  transacoes Transacao[]
}

model Transacao {
  id           String        @id @default(cuid())
  tipo         TipoTransacao
  valor        Float
  descricao    String
  data         DateTime
  safraId      String?
  safra        Safra?        @relation(fields: [safraId], references: [id])
  fornecedorId String?
  fornecedor   Fornecedor?   @relation(fields: [fornecedorId], references: [id])
  clienteId    String?
  cliente      Cliente?      @relation(fields: [clienteId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

enum TipoTransacao {
  RECEITA
  DESPESA
}

// ============================================================
// FROTA / INTELIGÊNCIA OPERACIONAL (pivô)
// ============================================================

model Ativo {
  id             String       @id @default(cuid())
  identificador  String       @unique // placa ou código (ex: "CAM-32")
  tipo           TipoAtivo    @default(CAMINHAO)
  status         StatusAtivo  @default(OCIOSO)
  fazendaId      String?
  fazenda        Fazenda?     @relation(fields: [fazendaId], references: [id])
  lat            Float?
  lng            Float?
  consumoMedio   Float        @default(0) // baseline L/h estimado
  consumoAtual   Float        @default(0) // L/h corrente (do feed simulado)
  capacidadeTanque Float?
  nivelCombustivel Float?      // % 0-100
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

enum TipoAtivo {
  CAMINHAO
  COLHEDORA
  TRATOR
  PULVERIZADOR
  OUTRO
}

enum StatusAtivo {
  EM_OPERACAO
  NA_FILA
  EM_TRANSITO
  OCIOSO
  MANUTENCAO
}

model Recomendacao {
  id              String              @id @default(cuid())
  tick            Int                 @default(0) // qual ciclo da simulação gerou
  tipo            TipoRecomendacao
  severidade      Severidade          @default(MEDIA)
  mensagem        String
  ativoId         String?
  fazendaOrigemId String?
  fazendaDestinoId String?
  status          StatusRecomendacao  @default(ATIVA)
  createdAt       DateTime            @default(now())
}

enum TipoRecomendacao {
  REDESPACHO
  FILA_ALTA
  ALERTA_CONSUMO
  ABASTECIMENTO
}

enum Severidade {
  BAIXA
  MEDIA
  ALTA
}

enum StatusRecomendacao {
  ATIVA
  RESOLVIDA
}

// Estado global da simulação (1 linha). Controla o "tick".
model SimState {
  id        String   @id @default(cuid())
  tick      Int      @default(0)
  updatedAt DateTime @updatedAt
}
